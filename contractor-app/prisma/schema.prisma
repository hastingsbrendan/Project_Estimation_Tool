generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Auth.js v5 required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  projects     Project[]
  catalogItems CatalogItem[]
  receipts     Receipt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model Project {
  id              String   @id @default(cuid())
  name            String
  clientName      String?
  clientEmail     String?
  address         String?
  status          String   @default("draft") // draft | sent | accepted | rejected | won | lost
  archived        Boolean  @default(false) // hide from main dashboard, keeps data intact
  taxRate         Float    @default(0) // percent (0-100); applies to materials only
  markupPct       Float    @default(0) // percent (0-100); applies to subtotal
  notes           String? // free-form jobsite notes
  scope           String? // proposal scope of work (markdown allowed)
  exclusions      String? // proposal exclusions
  paymentSchedule String? // proposal payment schedule
  proposalSentAt  DateTime? // when the proposal email was last sent
  shareToken      String?   @unique // public read-only proposal link
  // Public proposal acceptance (recorded when client signs on /proposal/[token])
  acceptedAt        DateTime?
  acceptedBy        String? // typed name from the client signature form
  acceptedIp        String? // client IP at sign time, for audit
  acceptedUserAgent String? // client UA at sign time, for audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          String

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections Section[]
  rooms    Room[]
  photos   Photo[]
  receipts Receipt[]

  @@index([userId])
}

/// Vendor receipts attached to a project. Captures what was actually spent
/// vs. what was estimated. Each receipt has its own line items (parsed by
/// Claude vision when a key is configured, otherwise manually entered).
model Receipt {
  id            String    @id @default(cuid())
  userId        String
  projectId     String? // optional — receipts can sit unassigned until you decide which job they belong to
  imageUrl      String // Vercel Blob URL of the receipt photo / PDF
  imagePathname String // for blob delete later
  filename      String
  size          Int? // bytes
  vendor        String? // e.g. "The Home Depot"
  purchasedAt   DateTime?
  subtotal      Float?
  tax           Float?
  total         Float?
  parseStatus   String    @default("pending") // pending | parsed | error | manual
  parseError    String? // surfaced to the user if Claude parsing failed
  parseRawJson  String? // raw model output for debugging
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items   ReceiptItem[]

  @@index([userId])
  @@index([projectId])
}

model ReceiptItem {
  id                   String  @id @default(cuid())
  receiptId            String
  description          String
  quantity             Float   @default(1)
  unit                 String  @default("ea")
  unitPrice            Float   @default(0)
  lineTotal            Float? // captured separately because retailers often print discounts that don't equal qty*unitPrice
  sku                  String?
  matchedCatalogItemId String? // optional — user (or matcher) links this back to a catalog item
  order                Int     @default(0)

  receipt        Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  matchedCatalog CatalogItem? @relation("MatchedReceiptItems", fields: [matchedCatalogItemId], references: [id], onDelete: SetNull)

  @@index([receiptId])
  @@index([matchedCatalogItemId])
}

model Photo {
  id        String   @id @default(cuid())
  url       String // public Vercel Blob URL
  pathname  String // for delete via @vercel/blob
  filename  String
  caption   String?
  size      Int? // bytes
  width     Int?
  height    Int?
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Room {
  id        String   @id @default(cuid())
  name      String   // e.g. "Kitchen", "Master bath"
  lengthFt  Float? // length in feet (optional)
  widthFt   Float? // width in feet (optional)
  heightFt  Float    @default(8) // ceiling height (default 8 ft)
  notes     String? // free-form: "10ft east wall has window 3x4", etc.
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Section {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems LineItem[]

  @@index([projectId])
}

model LineItem {
  id            String  @id @default(cuid())
  description   String
  quantity      Float   @default(1)
  unit          String  @default("ea") // ea, sqft, lf, hr, etc
  unitPrice     Float   @default(0)
  kind          String  @default("material") // "material" | "labor"
  order         Int     @default(0)
  sectionId     String
  catalogItemId String? // optional FK; null when line item was hand-typed

  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([sectionId])
  @@index([catalogItemId])
}

model CatalogItem {
  id          String   @id @default(cuid())
  trade       String   // demo, framing, plumbing, electrical, drywall, finish
  description String
  unit        String   @default("ea")
  unitPrice   Float    @default(0)
  kind        String   @default("material") // "material" | "labor"
  notes       String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems           LineItem[]
  servicePresets      CatalogPreset[] @relation("ServicePresets")  // when this is a labor item, these are its bundled materials
  materialPresets     CatalogPreset[] @relation("MaterialPresets") // when this is a material, these are presets that include it
  matchedReceiptItems ReceiptItem[]   @relation("MatchedReceiptItems")

  @@index([userId])
  @@index([trade])
}

/// Bundles materials with services. Per-user via the CatalogItem ownership chain.
/// When adding a service line item to a project, we surface its presets so
/// the contractor can accept-all (or pick a subset) and skip individually
/// searching for the typical materials.
model CatalogPreset {
  id         String   @id @default(cuid())
  serviceId  String   // CatalogItem with kind="labor"
  materialId String   // CatalogItem with kind="material"
  defaultQty Float    @default(1)
  notes      String?
  createdAt  DateTime @default(now())

  service  CatalogItem @relation("ServicePresets", fields: [serviceId], references: [id], onDelete: Cascade)
  material CatalogItem @relation("MaterialPresets", fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([serviceId, materialId])
  @@index([serviceId])
  @@index([materialId])
}
