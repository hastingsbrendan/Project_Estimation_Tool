# Database
# Local dev: use SQLite — DATABASE_URL="file:./dev.db"
# Production: use Postgres — DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL=""

# Auth.js v5 secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
AUTH_SECRET=""

# Required when not deploying to Vercel
AUTH_TRUST_HOST=true

# Email provider (Resend) — only needed for production magic links
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"
