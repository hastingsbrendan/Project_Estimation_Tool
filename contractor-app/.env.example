# Database
# Local dev: use SQLite — DATABASE_URL="file:./dev.db"
# Production (Turso): DATABASE_URL="libsql://your-db-name.turso.io"
DATABASE_URL=""
# Turso auth token — only needed in production (leave blank for local SQLite)
DATABASE_AUTH_TOKEN=""

# Auth.js v5 secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
AUTH_SECRET=""

# Required when not deploying to Vercel
AUTH_TRUST_HOST=true

# Email provider (Resend) — only needed for production magic links
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"
