generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Auth.js v5 required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  projects     Project[]
  catalogItems CatalogItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model Project {
  id              String   @id @default(cuid())
  name            String
  clientName      String?
  clientEmail     String?
  address         String?
  status          String   @default("draft") // draft | sent | accepted | rejected | won | lost
  archived        Boolean  @default(false) // hide from main dashboard, keeps data intact
  taxRate         Float    @default(0) // percent (0-100); applies to materials only
  markupPct       Float    @default(0) // percent (0-100); applies to subtotal
  notes           String? // free-form jobsite notes
  scope           String? // proposal scope of work (markdown allowed)
  exclusions      String? // proposal exclusions
  paymentSchedule String? // proposal payment schedule
  proposalSentAt  DateTime? // when the proposal email was last sent
  shareToken      String?   @unique // public read-only proposal link
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          String

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections Section[]
  rooms    Room[]
  photos   Photo[]

  @@index([userId])
}

model Photo {
  id        String   @id @default(cuid())
  url       String // public Vercel Blob URL
  pathname  String // for delete via @vercel/blob
  filename  String
  caption   String?
  size      Int? // bytes
  width     Int?
  height    Int?
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Room {
  id        String   @id @default(cuid())
  name      String   // e.g. "Kitchen", "Master bath"
  lengthFt  Float? // length in feet (optional)
  widthFt   Float? // width in feet (optional)
  heightFt  Float    @default(8) // ceiling height (default 8 ft)
  notes     String? // free-form: "10ft east wall has window 3x4", etc.
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Section {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  projectId String
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems LineItem[]

  @@index([projectId])
}

model LineItem {
  id            String  @id @default(cuid())
  description   String
  quantity      Float   @default(1)
  unit          String  @default("ea") // ea, sqft, lf, hr, etc
  unitPrice     Float   @default(0)
  kind          String  @default("material") // "material" | "labor"
  order         Int     @default(0)
  sectionId     String
  catalogItemId String? // optional FK; null when line item was hand-typed

  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([sectionId])
  @@index([catalogItemId])
}

model CatalogItem {
  id          String   @id @default(cuid())
  trade       String   // demo, framing, plumbing, electrical, drywall, finish
  description String
  unit        String   @default("ea")
  unitPrice   Float    @default(0)
  kind        String   @default("material") // "material" | "labor"
  notes       String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems LineItem[]

  @@index([userId])
  @@index([trade])
}
